{
  "manifest_version": 3,
  "name": "Alertly - Solana Intelligence",
  "version": "2.0.0",
  "description": "Real-time Solana alerts synced with your Alertly account — filters, auto-trade, copy trading, and more.",
  "permissions": ["notifications", "alarms", "storage"],
  "host_permissions": [
    "https://*.onrender.com/*",
    "https://*.replit.dev/*",
    "https://*.repl.co/*",
    "https://*.replit.app/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon128.png",
    "48": "icon128.png",
    "128": "icon128.png"
  }
}
