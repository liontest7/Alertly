{
  "manifest_version": 3,
  "name": "Alertly - Solana Intelligence",
  "version": "1.2.0",
  "description": "Real-time Solana alerts and synced trading preferences from Alertly.",
  "permissions": ["notifications", "alarms", "storage"],
  "host_permissions": [
    "https://*.onrender.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "128": "icon128.png"
  }
}
