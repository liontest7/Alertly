generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String               @id @default(cuid())
  walletAddress       String               @unique
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  vipLevel            Int                  @default(0)
  telegramId          String?              @unique
  extensionId         String?              @unique
  lastLogin           DateTime?
  copyTraders         CopyTrader[]
  telegramLink        TelegramLink?
  telegramLinkRequest TelegramLinkRequest?
  tradeExecutionLogs  TradeExecutionLog[]
  tradingWallet       TradingWallet?
  settings            UserSetting?
  walletConnections   WalletConnection[]
}

model AuthNonce {
  id        String    @id @default(cuid())
  nonce     String    @unique
  message   String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model WalletConnection {
  id            String   @id @default(cuid())
  userId        String
  walletAddress String   @unique
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model TradingWallet {
  id                  String   @id @default(cuid())
  userId              String   @unique
  walletAddress       String   @unique
  encryptedPrivateKey String
  createdAt           DateTime @default(now())
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model TelegramLink {
  id         String   @id @default(cuid())
  userId     String   @unique
  telegramId String   @unique
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model TelegramLinkRequest {
  id        String   @id @default(cuid())
  userId    String   @unique
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model UserSetting {
  id                   String   @id @default(cuid())
  userId               String   @unique
  buyAmount            Float    @default(0.5)
  maxBuyPerToken       Float    @default(2.0)
  slippage             Float    @default(10.0)
  autoTrade            Boolean  @default(false)
  minMarketCap         Float    @default(10000)
  maxMarketCap         Float    @default(10000000)
  minHolders           Int      @default(100)
  minLiquidity         Float    @default(50000)
  takeProfit           Float    @default(50)
  stopLoss             Float    @default(25)
  trailingStop         Boolean  @default(false)
  autoSellMinutes      Int      @default(0)
  volumeSpikeEnabled   Boolean  @default(true)
  volumeSpikeThreshold Int      @default(50)
  whaleAlertEnabled    Boolean  @default(true)
  whaleWalletAddresses String[] @default([])
  dexBoostEnabled      Boolean  @default(true)
  dexListingEnabled    Boolean  @default(true)
  sources              String[] @default(["Raydium", "Jupiter"])
  selectedBoostLevel   String?  @default("Top Boost")
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model CopyTrader {
  id            String   @id @default(cuid())
  userId        String
  traderAddress String
  buyAmount     Float    @default(0.5)
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, traderAddress])
  @@index([userId])
}

model TradeExecutionLog {
  id           String   @id @default(cuid())
  userId       String
  tokenAddress String
  alertType    String
  action       String
  amount       Float
  slippage     Float
  status       String
  txSig        String?
  message      String?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId, createdAt])
  @@index([tokenAddress, createdAt])
}

model AlertEvent {
  id          String   @id @default(cuid())
  fingerprint String   @unique
  address     String
  type        String
  name        String
  change      String
  trend       String
  mc          String
  vol         String
  liquidity   String
  holders     Int
  imageUrl    String?
  symbol      String?
  dexUrl      String?
  website     String?
  twitter     String?
  telegram    String?
  pairAddress String?
  priceUsd    String?
  riskScore   Float    @default(5.0)
  riskLevel   String   @default("MEDIUM")
  alertedAt   DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([address, alertedAt])
  @@index([riskScore, createdAt])
}

model BlockchainEvent {
  id            String   @id @default(cuid())
  signature     String   @unique
  tokenAddress  String
  eventType     String
  dex           String
  amount        Float?
  liquidity     Float?
  walletAddress String?
  timestamp     DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([tokenAddress, timestamp])
  @@index([eventType, createdAt])
  @@index([dex, timestamp])
}

model ListenerStatus {
  id            String    @id @default(cuid())
  name          String    @unique
  running       Boolean   @default(false)
  subscriptions Int       @default(0)
  lastEventAt   DateTime?
  errorsCount   Int       @default(0)
  lastError     String?
  uptime        Int       @default(0)
  updatedAt     DateTime  @updatedAt

  @@index([running, updatedAt])
}
