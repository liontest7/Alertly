# ============================================================
#  Alertly — Production Environment Variables
#  Copy this file to .env.production and fill in your values
#  All variables marked REQUIRED must be set before deploying
# ============================================================

# --- Database (REQUIRED) ---
DATABASE_URL="postgresql://user:password@host:5432/alertly"

# --- Auth (REQUIRED) ---
# Generate with: openssl rand -base64 32
JWT_SECRET="your-jwt-secret-here"

# --- Admin Access (REQUIRED) ---
# Comma-separated list of wallet addresses that have admin access
ADMIN_WALLETS="YourWalletAddress1,YourWalletAddress2"

# --- Solana RPC (REQUIRED for trading) ---
# Use a private RPC for best performance (Helius, QuickNode, etc.)
SOLANA_RPC_URL="https://mainnet.helius-rpc.com/?api-key=YOUR_KEY"

# --- Jupiter API (OPTIONAL) ---
# Default is the public lite API — use your own key for higher limits
JUPITER_API_URL="https://lite-api.jup.ag/swap/v1"

# --- Telegram Bot (OPTIONAL — needed for /start, /alerts etc.) ---
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_WEBHOOK_SECRET="your-webhook-secret"

# --- App URL (REQUIRED in production) ---
NEXT_PUBLIC_APP_URL="https://your-app.replit.app"

# --- DexScreener polling (do not change unless advised) ---
# Polling interval is hardcoded at 5-6s in the alert listener
# Do NOT set these — they are controlled by the code

# ============================================================
#  Deployment target: VM (always-running server)
#  Build command:     npm run build
#  Run command:       npm run start
#  Port:              10000 (set by the start script automatically)
# ============================================================
